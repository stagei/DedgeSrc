  "probeCodes": {
    "sqlcctcptest:11": {
      "component": "common communication",
      "description": "Detected client termination - Client connection was unexpectedly interrupted or terminated",
      "category": "Communication",
      "severity": "Error",
      "possibleCauses": [
        "Network interruptions",
        "Client application crash",
        "Firewall timeout on idle connections"
      ]
    },
    "sqlcctest:50": {
      "component": "common communication",
      "description": "Communication test return code - Internal communication test result",
      "category": "Communication",
      "severity": "Error"
    },
    "sqeAgent::AgentBreathingPoint:10": {
      "component": "base sys utilities",
      "description": "Agent breathing point - Agent detected an issue during processing",
      "category": "Agent",
      "severity": "Error"
    },
    "sqeAgent::AgentBreathingPoint:16": {
      "component": "base sys utilities",
      "description": "Agent breathing point with callstack - Agent waiting, may indicate lock contention",
      "category": "Agent",
      "severity": "Warning"
    },
    "sqlplfrDoScanNext:1015": {
      "component": "recovery manager",
      "description": "Log File Reader (LFR) scan operation - Scanning for log records",
      "category": "Recovery",
      "severity": "Warning",
      "possibleCauses": [
        "Normal LFR activity during database operations",
        "Log scanning for extent management"
      ]
    }
  },
  "messagePatterns": {
    "Detected client termination": {
      "description": "A client connection to the DB2 server was unexpectedly interrupted",
      "category": "Communication",
      "severity": "Error",
      "recommendation": "Check network stability, client application health, and firewall configurations"
    },
    "sqlcctest RC": {
      "description": "Internal communication test return code",
      "category": "Communication",
      "severity": "Error"
    }
  },
  "levelDescriptions": {
    "Critical": {
      "priority": 0,
      "description": "Highest severity level - Critical system failures that require immediate intervention",
      "action": "Immediate emergency response required"
    },
    "Severe": {
      "priority": 1,
      "description": "Critical errors that may cause significant disruptions",
      "action": "Immediate attention required"
    },
    "Error": {
      "priority": 2,
      "description": "Errors that require attention but are less critical than severe errors",
      "action": "Investigate and resolve promptly"
    },
    "Warning": {
      "priority": 3,
      "description": "Potential issues that might not immediately affect operations but could lead to problems",
      "action": "Monitor and address when possible"
    },
    "Info": {
      "priority": 4,
      "description": "General information about system operations and events",
      "action": "For informational purposes only"
    }
  }
