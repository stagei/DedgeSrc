{
  "TrayAppSettings": {
    // ServerMonitor API endpoint
    "ApiBaseUrl": "http://localhost:8999",
    
    // Remote control trigger files configuration
    "ConfigBasePath": "\\dedge-server\\DedgeCommon\\Software\\Config\\ServerMonitor",
    "ReinstallTriggerFileName": "ReinstallServerMonitor.txt",
    "StopTrayTriggerFileName": "StopServerMonitorTray.txt",
    
    // Path to check installed ServerMonitor version
    "ServerMonitorExePath": "\\dedge-server\\DedgeCommon\\Software\\DedgeWinApps\\ServerMonitor\\ServerMonitor.exe",
    
    // Status check interval in milliseconds
    "StatusCheckIntervalMs": 3000,
    
    // ═══════════════════════════════════════════════════════════════════════════════
    // ALERT NOTIFICATION SETTINGS
    // Show balloon notifications when new alerts occur
    // ═══════════════════════════════════════════════════════════════════════════════
    
    // Enable/disable balloon notifications for new alerts
    "EnableAlertNotifications": true,
    
    // How often to poll for new alerts (ms) - uses same timer as status check
    "AlertPollIntervalMs": 5000,
    
    // Suppress notifications for alerts that exist at startup (prevents storm)
    "SuppressStartupAlerts": true,
    
    // Max alert IDs to track in memory (older IDs are removed)
    "MaxSeenAlertIds": 1000,
    
    // How long to display balloon notification (ms)
    "BalloonDisplayTimeMs": 5000,
    
    // When balloon is clicked: true = open HTML report, false = open Swagger
    "OpenHtmlOnBalloonClick": true
  }
}
