<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <Package Name="DbExplorer"
           Language="1033"
           Version="1.0.2"
           Manufacturer="Dedge AS"
           UpgradeCode="0A22D7A1-62B2-4C03-9E33-572ABFFA3CDD"
           Compressed="yes">

    <MajorUpgrade DowngradeErrorMessage="A newer version of DbExplorer is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- PRODUCT METADATA (visible in Add/Remove Programs)                   -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <Property Id="ARPCOMMENTS"      Value="Multi-database explorer for DB2, PostgreSQL and SQLite. Developed by Dedge AS." />
    <Property Id="ARPCONTACT"       Value="Dedge AS" />
    <Property Id="ARPHELPLINK"      Value="https://www.dedge.no" />
    <Property Id="ARPURLINFOABOUT"  Value="https://www.dedge.no" />

    <!-- Kill any running instance before files are copied so nothing is locked -->
    <util:CloseApplication Id="CloseExistingApp"
                           Target="DbExplorer.exe"
                           CloseMessage="yes"
                           RebootPrompt="no"
                           TerminateProcess="0"
                           Timeout="5" />

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- DIRECTORIES                                                         -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="DedgeFolder" Name="Dedge">
        <Directory Id="INSTALLFOLDER" Name="DbExplorer" />
      </Directory>
    </StandardDirectory>

    <!-- FK users: override install path to AppLocker-approved location -->
    <SetProperty Id="INSTALLFOLDER"
                 Value="[%OptPath]\Programs\DbExplorer\"
                 Before="AppSearch"
                 Sequence="both"
                 Condition="%USERNAME ~&lt;&lt; &quot;FK&quot;" />

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="AppMenuFolder" Name="Dedge" />
    </StandardDirectory>

    <StandardDirectory Id="DesktopFolder" />

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- COMPONENTS                                                          -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <ComponentGroup Id="Shortcuts" Directory="AppMenuFolder">
      <Component Id="StartMenuShortcut" Guid="0D7FCBF7-B7FE-4B8A-BFC0-4E3D4828F831">
        <Shortcut Id="AppStartMenuShortcut"
                  Name="DbExplorer"
                  Description="Multi-database explorer for DB2, PostgreSQL and SQLite"
                  Target="[INSTALLFOLDER]DbExplorer.exe"
                  WorkingDirectory="INSTALLFOLDER"
                  Icon="AppIcon" />
        <RemoveFolder Id="RemoveAppMenuFolder" Directory="AppMenuFolder" On="uninstall" />
        <RegistryValue Root="HKCU"
                       Key="Software\Dedge\DbExplorer"
                       Name="StartMenuInstalled"
                       Type="integer" Value="1"
                       KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <ComponentGroup Id="DesktopShortcuts" Directory="DesktopFolder">
      <Component Id="DesktopShortcut" Guid="B919A7CF-1947-4FCC-B413-AFBC24A6A09D">
        <Shortcut Id="AppDesktopShortcut"
                  Name="DbExplorer"
                  Description="Multi-database explorer for DB2, PostgreSQL and SQLite"
                  Target="[INSTALLFOLDER]DbExplorer.exe"
                  WorkingDirectory="INSTALLFOLDER"
                  Icon="AppIcon" />
        <RegistryValue Root="HKCU"
                       Key="Software\Dedge\DbExplorer"
                       Name="DesktopInstalled"
                       Type="integer" Value="1"
                       KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- FEATURE                                                             -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <Feature Id="ProductFeature" Title="DbExplorer" Level="1">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentGroupRef Id="Shortcuts" />
      <ComponentGroupRef Id="DesktopShortcuts" />
    </Feature>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- CUSTOM ACTION                                                       -->
    <!-- Launch the app immediately after install (fire and forget)          -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <CustomAction Id="LaunchApp"
                  Directory="INSTALLFOLDER"
                  Execute="immediate"
                  Return="asyncNoWait"
                  ExeCommand="&quot;[INSTALLFOLDER]DbExplorer.exe&quot;" />

    <InstallUISequence>
      <Custom Action="LaunchApp" After="ExecuteAction" Condition="NOT Installed AND NOT REMOVE" />
    </InstallUISequence>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- UI                                                                  -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <Icon Id="AppIcon" SourceFile="..\Resources\dEdge.ico" />
    <Property Id="ARPPRODUCTICON" Value="AppIcon" />

    <WixVariable Id="WixUILicenseRtf" Value="License.rtf" />

    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER" />

  </Package>

</Wix>
