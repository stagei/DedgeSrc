<Window x:Class="DbExplorer.Dialogs.ConnectionManagerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="Manage Connections"
        Icon="pack://application:,,,/Resources/dEdge.ico"
        Width="700"
        Height="500"
        MinWidth="550"
        MinHeight="350"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Saved Connection Profiles" FontSize="16" FontWeight="SemiBold"
                   Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}" Margin="0,0,0,10"/>

        <DataGrid Grid.Row="1" x:Name="ConnectionsGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  AlternatingRowBackground="{DynamicResource SystemControlBackgroundAltHighBrush}"
                  GridLinesVisibility="Horizontal"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  MouseDoubleClick="ConnectionsGrid_DoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" MinWidth="150"/>
                <DataGridTextColumn Header="Provider" Binding="{Binding Provider}" Width="90"/>
                <DataGridTextColumn Header="Server" Binding="{Binding Server}" Width="*" MinWidth="120"/>
                <DataGridTextColumn Header="Database" Binding="{Binding Database}" Width="120"/>
                <DataGridTextColumn Header="User" Binding="{Binding Username}" Width="100"/>
                <DataGridTextColumn Header="Last Used" Binding="{Binding LastUsed, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" Width="130"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
            <Button Content="New" Click="New_Click" Padding="15,6" Margin="0,0,8,0"/>
            <Button Content="Edit" Click="Edit_Click" Padding="15,6" Margin="0,0,8,0"/>
            <Button Content="Duplicate" Click="Duplicate_Click" Padding="15,6" Margin="0,0,8,0"/>
            <Button Content="Delete" Click="Delete_Click" Padding="15,6" Foreground="IndianRed"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Connect" Click="Connect_Click" Padding="20,6" Margin="0,0,8,0"
                    Style="{StaticResource AccentButtonStyle}"/>
            <Button Content="Close" Click="Close_Click" Padding="20,6" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
