  "query": "SELECT\r\n    TRIM(TABNAME)    AS TABNAME,\r\n    TRIM(TABSCHEMA)  AS TABSCHEMA,\r\n    TYPE,\r\n    TRIM(REMARKS)    AS REMARKS,\r\n    COLCOUNT,\r\n    TRIM(TABSCHEMA) || '.' || TRIM(TABNAME) AS QUALIFIED_NAME\r\nFROM SYSCAT.TABLES\r\nWHERE TABSCHEMA NOT LIKE '%SYS%'\r\n  AND TABSCHEMA NOT LIKE '%IBM%'\r\n  AND TABSCHEMA <> 'ROA'\r\nORDER BY TABSCHEMA, TABNAME",
