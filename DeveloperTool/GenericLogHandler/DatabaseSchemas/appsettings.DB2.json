{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost:50000;Database=LOGS;UID=loghandler;PWD=SecurePassword123!;Security=SSL;Connection Timeout=15;Command Timeout=30;"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },
  "DB2": {
    "Server": "localhost",
    "Port": 50000,
    "Database": "LOGS",
    "UserId": "loghandler",
    "Password": "SecurePassword123!",
    "Security": "SSL",
    "CommandTimeout": 30,
    "ConnectionTimeout": 15,
    "CurrentSchema": "LOGHANDLER"
  },
  "ImportService": {
    "PollingIntervalSeconds": 30,
    "BatchSize": 1000,
    "MaxRetries": 3,
    "RetryDelaySeconds": 5,
    "HealthCheckIntervalSeconds": 60,
    "Sources": [
      {
        "Name": "Windows Event Log",
        "Type": "eventlog",
        "Enabled": true,
        "Config": {
          "LogNames": ["Application", "System", "Security"],
          "MaxEventsPerPoll": 1000,
          "PollingIntervalSeconds": 30
        }
      },
      {
        "Name": "File Watcher",
        "Type": "file",
        "Enabled": true,
        "Config": {
          "WatchPath": "C:\\Logs",
          "FilePattern": "*.log",
          "IncludeSubdirectories": true
        }
      }
    ]
  },
  "DataRetention": {
    "DefaultRetentionDays": 90,
    "ArchiveBeforeDelete": true,
    "ArchivePath": "C:\\LogArchive",
    "CleanupSchedule": "0 2 * * *"
  },
  "Security": {
    "RequireAuthentication": true,
    "AllowedRoles": ["Log Administrators", "Log Users"],
    "RateLimiting": {
      "RequestsPerMinute": 100,
      "BurstLimit": 20
    }
  }
}
