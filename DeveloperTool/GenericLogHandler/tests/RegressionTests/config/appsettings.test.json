{
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=8432;Database=GenericLogHandler;Username=postgres;Password=postgres",
    "DefaultConnection": "Host=localhost;Port=8432;Database=GenericLogHandler;Username=postgres;Password=postgres"
  },
  "ImportConfiguration": {
    "database": {
      "type": "postgres"
    }
  },
  "DedgeAuth": {
    "Enabled": false
  },
  "JobTracking": {
    "EnableJobCorrelation": true,
    "CheckIntervalMinutes": 1,
    "OrphanTimeoutHours": 24,
    "AutoMarkOrphanedJobs": true
  },
  "SmtpSettings": {
    "Host": "",
    "Port": 25
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
