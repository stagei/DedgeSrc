<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <Fragment>
    <!--
      All files from the published tray app output are included via a WiX v6 glob.
      Each matched file gets its own auto-generated component, keyed by file path.
      The publish profile must use PublishSingleFile=false for this to work.
    -->
    <ComponentGroup Id="TrayAppFiles" Directory="INSTALLFOLDER">
      <Files Include="..\IIS-AutoDeploy.Tray\bin\Release\net10.0-windows\win-x64\publish\**\*" />
    </ComponentGroup>
  </Fragment>

</Wix>
