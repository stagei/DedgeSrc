<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- 
    NuGet Configuration for SqlMermaidErdTools
    
    This file configures package sources including GitHub Packages.
    
    IMPORTANT: Do NOT commit credentials to source control!
    Use environment variables or the dotnet nuget commands instead.
  -->
  
  <packageSources>
    <!-- Clear default sources to have full control -->
    <clear />
    
    <!-- Official NuGet.org feed (for dependencies) -->
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    
    <!-- 
      GitHub Packages: Private NuGet Feed for SqlMermaidErdTools
      Owner: stagei (geir@starholm.net)
      
      To configure credentials, run:
        dotnet nuget update source github [username] [password] [store password in clear text]
    -->
    <add key="github" value="https://nuget.pkg.github.com/stagei/index.json" protocolVersion="3" />
  </packageSources>
  
  <packageSourceMapping>
    <!-- Use NuGet.org for all packages by default -->
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
    
    <!-- Use GitHub for SqlMermaidErdTools packages -->
    <packageSource key="github">
      <package pattern="SqlMermaidErdTools*" />
    </packageSource>
  </packageSourceMapping>
  
  <!-- 
    Package Source Credentials
    
    NOTE: For security, credentials should be added via CLI, not in this file.
    
    To add credentials:
      dotnet nuget update source github [username] [password] [store password in clear text]
    
    Or use environment variables in CI/CD:
      NUGET_AUTH_TOKEN=your_token
  -->
  
</configuration>

