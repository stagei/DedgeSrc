{
  "SiteName": "ServerMonitorDashboard",
  "PhysicalPath": "$env:OptPath\\DedgeWinApps\\ServerMonitorDashboard",
  "AppType": "AspNetCore",
  "DotNetDll": "ServerMonitorDashboard.dll",
  "AppPoolName": "ServerMonitorDashboard",
  "InstallSource": "WinApp",
  "InstallAppName": "ServerMonitorDashboard",
  "VirtualPath": "/ServerMonitorDashboard",
  "ParentSite": "Default Web Site",
  "HealthEndpoint": "/api/IsAlive",
  "EnableDirectoryBrowsing": false,
  "IsRootSiteProfile": false,
  "AllowAnonymousAccess": true,
  "ApiPort": 8998,
