  "DedgeAuth": {
    "AppId": "ServerMonitorDashboard",
    "DisplayName": "Server Monitor Dashboard",
    "Description": "Real-time server monitoring and alerting",
    "Roles": ["User", "Admin"],
    "TenantDomains": ["Dedge.no"],
    "BaseUrl": "http://$env:COMPUTERNAME/ServerMonitorDashboard",
