{
  "$schema": "./theme-schema.json",
  "ThemeName": "Windows 11 Dark Mode",
  "Version": "1.1",
  "Author": "Geir Helge Starholm, www.dEdge.no",
  "Description": "Applies Windows 11 dark mode colors to legacy Windows components including treeviews and tabs",
  "Colors": {
    "Window": {
      "Background": "32 32 32",
      "Text": "240 240 240",
      "Frame": "55 55 55",
      "Description": "Main window/treeview background and text"
    },
    "Menu": {
      "Background": "43 43 43",
      "Text": "240 240 240",
      "Bar": "38 38 38",
      "Description": "Menu bar and context menu"
    },
    "MenuHighlight": {
      "Background": "65 65 65",
      "Text": "255 255 255",
      "Description": "Selected menu item"
    },
    "ButtonFace": {
      "Background": "50 50 50",
      "Description": "Button, dialog, tab, and control backgrounds"
    },
    "ButtonText": {
      "Color": "240 240 240",
      "Description": "Button and control text color"
    },
    "ButtonHighlight": {
      "Color": "70 70 70",
      "Description": "Button/control light edge (3D effect)"
    },
    "ButtonShadow": {
      "Color": "25 25 25",
      "Description": "Button/control dark edge (3D effect)"
    },
    "ButtonLight": {
      "Color": "60 60 60",
      "Description": "3D control light surface"
    },
    "ButtonDkShadow": {
      "Color": "20 20 20",
      "Description": "3D control darkest shadow"
    },
    "ButtonAlternateFace": {
      "Color": "45 45 45",
      "Description": "Alternate 3D button face"
    },
    "ActiveTitle": {
      "Background": "0 120 215",
      "Text": "255 255 255",
      "Description": "Active window title bar"
    },
    "InactiveTitle": {
      "Background": "45 45 45",
      "Text": "180 180 180",
      "Description": "Inactive window title bar"
    },
    "GradientActiveTitle": {
      "Color": "0 100 180",
      "Description": "Active title bar gradient end"
    },
    "GradientInactiveTitle": {
      "Color": "55 55 55",
      "Description": "Inactive title bar gradient end"
    },
    "GrayText": {
      "Color": "128 128 128",
      "Description": "Disabled/grayed text"
    },
    "Highlight": {
      "Background": "0 120 215",
      "Text": "255 255 255",
      "Description": "Selected item in lists/trees"
    },
    "HotTrackingColor": {
      "Color": "102 180 234",
      "Description": "Hyperlink and hot tracking color"
    },
    "Scrollbar": {
      "Background": "38 38 38",
      "Description": "Scrollbar track background"
    },
    "AppWorkspace": {
      "Background": "28 28 28",
      "Description": "MDI application workspace/background"
    },
    "InfoWindow": {
      "Background": "50 50 50",
      "Text": "240 240 240",
      "Description": "Tooltip background and text"
    },
    "ActiveBorder": {
      "Color": "55 55 55",
      "Description": "Active window border"
    },
    "InactiveBorder": {
      "Color": "45 45 45",
      "Description": "Inactive window border"
    },
    "Background": {
      "Color": "0 0 0",
      "Description": "Desktop background"
    }
  },
  "RegistryPaths": {
    "Colors": "HKEY_CURRENT_USER\\Control Panel\\Colors",
    "Desktop": "HKEY_CURRENT_USER\\Control Panel\\Desktop",
    "DWM": "HKEY_CURRENT_USER\\Software\\Microsoft\\Windows\\DWM"
  },
  "Notes": [
    "This configuration applies dark mode colors to legacy Windows components",
    "Treeviews, tabs, and 3D controls use coordinated dark grey shades",
    "Changes require logging out and back in to take full effect",
    "Some applications may need to be restarted to see changes",
    "MMC snap-ins (Task Scheduler, Event Viewer, etc.) will be partially affected",
    "Use 'Revert' functionality to restore original colors"
  ]
}

