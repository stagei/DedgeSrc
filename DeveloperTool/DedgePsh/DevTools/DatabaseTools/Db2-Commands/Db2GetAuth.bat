db2 SELECT (CASE MAX(BINDADDAUTH) WHEN 'Y' THEN 1 ELSE 0 END + CASE MAX(CONNECTAUTH) WHEN 'Y' THEN 1 ELSE 0 END + CASE MAX(CREATETABAUTH) WHEN 'Y' THEN 1 ELSE 0 END + CASE MAX(DBADMAUTH) WHEN 'Y' THEN 1 ELSE 0 END + CASE MAX(EXTERNALROUTINEAUTH) WHEN 'Y' THEN 1 ELSE 0 END + CASE MAX(IMPLSCHEMAAUTH) WHEN 'Y' THEN 1 ELSE 0 END + CASE MAX(LOADAUTH) WHEN 'Y' THEN 1 ELSE 0 END + CASE MAX(NOFENCEAUTH) WHEN 'Y' THEN 1 ELSE 0 END + CASE MAX(QUIESCECONNECTAUTH) WHEN 'Y' THEN 1 ELSE 0 END + CASE MAX(SECURITYADMAUTH) WHEN 'Y' THEN 1 ELSE 0 END + CASE MAX(SQLADMAUTH) WHEN 'Y' THEN 1 ELSE 0 END + CASE MAX(WLMADMAUTH) WHEN 'Y' THEN 1 ELSE 0 END + CASE MAX(EXPLAINAUTH) WHEN 'Y' THEN 1 ELSE 0 END + CASE MAX(DATAACCESSAUTH) WHEN 'Y' THEN 1 ELSE 0 END + CASE MAX(ACCESSCTRLAUTH) WHEN 'Y' THEN 1 ELSE 0 END + CASE MAX(CREATESECUREAUTH) WHEN 'Y' THEN 1 ELSE 0 END ) AS AUTHORITEIS_ASSIGNED, GRANTEE, MAX(BINDADDAUTH) AS BINDADDAUTH, MAX(CONNECTAUTH) AS CONNECTAUTH, MAX(CREATETABAUTH) AS CREATETABAUTH, MAX(DBADMAUTH) AS DBADMAUTH, MAX(EXTERNALROUTINEAUTH) AS EXTERNALROUTINEAUTH, MAX(IMPLSCHEMAAUTH) AS IMPLSCHEMAAUTH, MAX(LOADAUTH) AS LOADAUTH, MAX(NOFENCEAUTH) AS NOFENCEAUTH, MAX(QUIESCECONNECTAUTH) AS QUIESCECONNECTAUTH, MAX(SECURITYADMAUTH) AS SECURITYADMAUTH, MAX(SQLADMAUTH) AS SQLADMAUTH, MAX(WLMADMAUTH) AS WLMADMAUTH, MAX(EXPLAINAUTH) AS EXPLAINAUTH, MAX(DATAACCESSAUTH) AS DATAACCESSAUTH, MAX(ACCESSCTRLAUTH) AS ACCESSCTRLAUTH, MAX(CREATESECUREAUTH) AS CREATESECUREAUTH, MAX(GRANT_TIME) AS GRANT_TIME, MAX(GRANTREVOKE_TIME) AS GRANTREVOKE_TIME FROM SYSCAT.DBAUTH GROUP BY GRANTEE ORDER BY AUTHORITEIS_ASSIGNED DESC

