echo - OLE DB: %CLIENT_CONFIG_DIR_OLEDB%\Uninstall-Db2-SSL-Support-OleDb.bat

set /a STEP+=1
echo.
powershell -Command "Write-Host Step %STEP% - Creating comprehensive Windows SSO setup guide... -ForegroundColor Yellow"
echo # DB2 SSL Client Setup Guide - Windows SSO                                                                                                                                  > "%COMMON_EXPORT_DIR%\Client SSO Setup Guide.md"                        
echo.                                                                                                                                                                            >> "%COMMON_EXPORT_DIR%\Client SSO Setup Guide.md"
echo **Server:** %SERVER_HOSTNAME%                                                                                                                                               >> "%COMMON_EXPORT_DIR%\Client SSO Setup Guide.md"
echo **Generated:** %DATE% %TIME%                                                                                                                                                >> "%COMMON_EXPORT_DIR%\Client SSO Setup Guide.md"
echo **Database:** %DATABASE_NAME%                                                                                                                                               >> "%COMMON_EXPORT_DIR%\Client SSO Setup Guide.md"
echo **SSL Port:** %SSL_PORT%                                                                                                                                                    >> "%COMMON_EXPORT_DIR%\Client SSO Setup Guide.md"
echo.                                                                                                                                                                            >> "%COMMON_EXPORT_DIR%\Client SSO Setup Guide.md"
echo ---                                                                                                                                                                         >> "%COMMON_EXPORT_DIR%\Client SSO Setup Guide.md"
echo.                                                                                                                                                                            >> "%COMMON_EXPORT_DIR%\Client SSO Setup Guide.md"
echo ## 🚀 Windows SSO Quick Start                                                                                                                                               >> "%COMMON_EXPORT_DIR%\Client SSO Setup Guide.md"
echo.                                                                                                                                                                            >> "%COMMON_EXPORT_DIR%\Client SSO Setup Guide.md"
echo 1. **Configure DBeaver:** Installs ini file and Use connection strings from `ClientSetup\Dbeaver\main_setup_dbeaver.bat`                                                    >> "%COMMON_EXPORT_DIR%\Client SSO Setup Guide.md"
echo    
echo 1. **Install SSL Certificate:** Run `ClientSetup\Dbeaver\Install-Db2-SSL-Support-Dbeaver.bat`                                                              >> "%COMMON_EXPORT_DIR%\Client SSO Setup Guide.md"
echo 2. **Setup Windows SSO:** Run `ClientSetup\Distribute-KRB5-Ini-File-To-Client-Windir.bat`                                                                                                    >> "%COMMON_EXPORT_DIR%\Client SSO Setup Guide.md"
echo 4. **Test Connection:** Run `ClientSetup\Test-Ssl-Connection-From-Client.bat`                                                                                                           >> "%COMMON_EXPORT_DIR%\Client SSO Setup Guide.md"
echo 5. **Leave username/password EMPTY** in DBeaver - uses Windows domain login automatically                                                                                   >> "%COMMON_EXPORT_DIR%\Client SSO Setup Guide.md"
echo.                                                                                                                                                                            >> "%COMMON_EXPORT_DIR%\Client SSO Setup Guide.md"
echo ## 🔗 JDBC Connection Strings                                                                                                                                               >> "%COMMON_EXPORT_DIR%\Client SSO Setup Guide.md"
echo.                                                                                                                                                                            >> "%COMMON_EXPORT_DIR%\Client SSO Setup Guide.md"
echo ### ✅ Recommended (Windows SSPI)                                                                                                                                           >> "%COMMON_EXPORT_DIR%\Client SSO Setup Guide.md"
echo ```                                                                                                                                                                         >> "%COMMON_EXPORT_DIR%\Client SSO Setup Guide.md"
echo jdbc:db2://%SERVER_HOSTNAME%:%SSL_PORT%/%DATABASE_NAME%:securityMechanism=15;sslConnection=true;                                                                            >> "%COMMON_EXPORT_DIR%\Client SSO Setup Guide.md"
echo ```                                                                                                                                                                         >> "%COMMON_EXPORT_DIR%\Client SSO Setup Guide.md"
echo.                                                                                                                                                                            >> "%COMMON_EXPORT_DIR%\Client SSO Setup Guide.md"
echo ### 🔄 Alternative (Kerberos)                                                                                                                                               >> "%COMMON_EXPORT_DIR%\Client SSO Setup Guide.md"
echo ```                                                                                                                                                                         >> "%COMMON_EXPORT_DIR%\Client SSO Setup Guide.md"
echo jdbc:db2://%SERVER_HOSTNAME%:%SSL_PORT%/%DATABASE_NAME%:securityMechanism=11;sslConnection=true;kerberosServerPrincipal=db2/%SERVER_HOSTNAME%@DEDGE.FK.NO;                 >> "%COMMON_EXPORT_DIR%\Client SSO Setup Guide.md"
echo ```                                                                                                                                                                         >> "%COMMON_EXPORT_DIR%\Client SSO Setup Guide.md"
echo.                                                                                                                                                                            >> "%COMMON_EXPORT_DIR%\Client SSO Setup Guide.md"
echo ## 🔐 Security Mechanism Explanation                                                                                                                                        >> "%COMMON_EXPORT_DIR%\Client SSO Setup Guide.md"
echo.                                                                                                                                                                            >> "%COMMON_EXPORT_DIR%\Client SSO Setup Guide.md"
echo ^| Mechanism ^| Description ^| Requirements ^|                                                                                                                              >> "%COMMON_EXPORT_DIR%\Client SSO Setup Guide.md"
echo ^|----------^|-------------^|--------------^|                                                                                                                               >> "%COMMON_EXPORT_DIR%\Client SSO Setup Guide.md"
echo ^| `securityMechanism=15` ^| Windows SSPI (Simplest) ^| No krb5.ini needed ^|                                                                                               >> "%COMMON_EXPORT_DIR%\Client SSO Setup Guide.md"
echo ^| `securityMechanism=11` ^| Kerberos Authentication ^| May need krb5.ini for some clients ^|                                                                               >> "%COMMON_EXPORT_DIR%\Client SSO Setup Guide.md"
echo.                                                                                                                                                                            >> "%COMMON_EXPORT_DIR%\Client SSO Setup Guide.md"
echo ## 📁 Folder Structure                                                                                                                                                      >> "%COMMON_EXPORT_DIR%\Client SSO Setup Guide.md"
echo.                                                                                                                                                                            >> "%COMMON_EXPORT_DIR%\Client SSO Setup Guide.md"
echo ```                                                                                                                                                                         >> "%COMMON_EXPORT_DIR%\Client SSO Setup Guide.md"
echo %COMPUTERNAME%\                                                                                                                                                             >> "%COMMON_EXPORT_DIR%\Client SSO Setup Guide.md"
echo ├── 📄 Client SSO Setup Guide.md                                       # This comprehensive setup guide                                                                     >> "%COMMON_EXPORT_DIR%\Client SSO Setup Guide.md"
echo ├── 📁 Certificate\                                                    # SSL Certificate Files                                                                              >> "%COMMON_EXPORT_DIR%\Client SSO Setup Guide.md"
echo │   └── 📄 db2-server-cert.cer                                         # Server SSL certificate for import                                                                  >> "%COMMON_EXPORT_DIR%\Client SSO Setup Guide.md"
echo ├── 📁 ClientSetup\                                                    # Client Configuration Files                                                                         >> "%COMMON_EXPORT_DIR%\Client SSO Setup Guide.md"
