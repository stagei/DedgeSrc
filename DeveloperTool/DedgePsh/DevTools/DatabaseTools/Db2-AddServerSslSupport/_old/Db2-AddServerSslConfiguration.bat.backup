echo echo Testing current Kerberos ticket...                                                                                                                                                   >> "%CLIENT_CONFIG_DIR%\Test-Ssl-Connection-From-Client.bat"
echo klist                                                                                                                                                                                     >> "%CLIENT_CONFIG_DIR%\Test-Ssl-Connection-From-Client.bat"
echo.                                                                                                                                                                                          >> "%CLIENT_CONFIG_DIR%\Test-Ssl-Connection-From-Client.bat"
echo echo If you see tickets above, Windows SSO should work with DB2.                                                                                                                          >> "%CLIENT_CONFIG_DIR%\Test-Ssl-Connection-From-Client.bat"

echo - Client configuration files created in: %CLIENT_CONFIG_DIR%
echo %DATE% %TIME% - Client configuration files created (SSO mode) >> "%LOGFILE%"


echo.
powershell -Command "Write-Host ========================================================================== -ForegroundColor Cyan"
echo Exporting SSL certificate for client import
powershell -Command "Write-Host ========================================================================== -ForegroundColor Cyan"
echo.


set SERVER_HOSTNAME=%COMPUTERNAME%.DEDGE.fk.no
set CERT_SCRIPTS_DIR=%COMMON_EXPORT_DIR%\Certificate
set LOGFILE=%LOG_DIR%\cert_export_%DATE:~-4,4%%DATE:~-10,2%%DATE:~-7,2%_%TIME:~0,2%%TIME:~3,2%%TIME:~6,2%.log
echo %DATE% %TIME% - Starting Certificate Export >> "%LOGFILE%"

REM Create enhanced directory structure

REM Clean certificate scripts directory
del "%CERT_SCRIPTS_DIR%\*.bat" 2>nul
del "%CERT_SCRIPTS_DIR%\*.cer" 2>nul

echo Configuration:
echo - SSL Directory: %SSL_DIR%
echo - Certificate Label: %CERT_LABEL%
echo - Server Hostname: %SERVER_HOSTNAME%
echo - Output Directory: %COMMON_EXPORT_DIR%
echo - Certificate File: %CERT_FILE%
echo - Client Config Directory: %CLIENT_CONFIG_DIR%
echo - Certificate Scripts Directory: %CERT_SCRIPTS_DIR%
echo - Authentication Mode: Windows SSO 
echo.

set /a STEP+=1
echo.
powershell -Command "Write-Host Step %STEP% - Listing certificates in keystore... -ForegroundColor Yellow"
"%GSKIT_PATH%\gsk8capicmd_64.exe" -cert -list -db "%SSL_DIR%\server.kdb" -pw "%SSL_PASSWORD%"

set /a STEP+=1
echo.
powershell -Command "Write-Host Step %STEP% - Extracting certificate to file... -ForegroundColor Yellow"
del "%CERT_FILE%" /f /q 2>nul
"%GSKIT_PATH%\gsk8capicmd_64.exe" -cert -extract -db "%SSL_DIR%\server.kdb" -pw "%SSL_PASSWORD%" -label "%CERT_LABEL%" -target "%CERT_FILE%"  
if errorlevel 1 (
    echo ERROR: Failed to extract certificate
    echo %DATE% %TIME% - ERROR: Failed to extract certificate >> "%LOGFILE%"
    pause
    exit /b 1
)

echo - Certificate extracted successfully to: %CERT_FILE%
echo %DATE% %TIME% - Certificate extracted successfully >> "%LOGFILE%"

REM Copy certificate to multiple locations for client convenience
copy "%CERT_FILE%" "%CERT_SCRIPTS_DIR%\" >nul

set /a STEP+=1
echo.
powershell -Command "Write-Host Step %STEP% - Displaying certificate details... -ForegroundColor Yellow"
"%GSKIT_PATH%\gsk8capicmd_64.exe" -cert -details -db "%SSL_DIR%\server.kdb" -pw "%SSL_PASSWORD%" -label "%CERT_LABEL%" 



echo.
powershell -Command "Write-Host ========================================================================== -ForegroundColor Cyan"
echo Certificate Extraction Completed!
powershell -Command "Write-Host ========================================================================== -ForegroundColor Cyan"



echo.
powershell -Command "Write-Host ========================================================================== -ForegroundColor Cyan"
echo Creating Enhanced Client Import Scripts 
powershell -Command "Write-Host ========================================================================== -ForegroundColor Cyan"
echo.
@REM :test
copy "%OptPath%\DedgePshApps\Db2-AddServerSslSupport\Manage-ClientCertificates.ps1" "%CLIENT_CONFIG_DIR_JAVA%"
copy "%OptPath%\DedgePshApps\Db2-AddServerSslSupport\Manage-ClientCertificates.ps1" "%CLIENT_CONFIG_DIR_DBEAVER%"
copy "%OptPath%\DedgePshApps\Db2-AddServerSslSupport\Manage-ClientCertificates.ps1" "%CLIENT_CONFIG_DIR_OLEDB%"




set /a STEP+=1
echo.
powershell -Command "Write-Host Step %STEP% - Creating enhanced certificate management scripts using PowerShell generator... -ForegroundColor Yellow"

REM Generate Java/JDBC certificate management scripts
echo Creating Java/JDBC certificate import script...
pwsh.exe -ExecutionPolicy Bypass -File "%OptPath%\DedgePshApps\Db2-AddServerSslSupport\Generate-ClientCertificateHandlingScripts.ps1" -OutputFileName "%CLIENT_CONFIG_DIR_JAVA%\Install-Db2-SSL-Support-Java.bat" -ServerHostname "%SERVER_HOSTNAME%" -CertFile "%CERT_FILE%" -Action "add" -Target "java" -Krb5IniPath "%KERBEROS_DIR%\krb5.ini" -SslPort "%SSL_PORT%" -DatabaseName "%DATABASE_NAME%" -DatabasePort "%DATABASE_PORT%"

echo Creating Java/JDBC certificate removal script...
pwsh.exe -ExecutionPolicy Bypass -File "%OptPath%\DedgePshApps\Db2-AddServerSslSupport\Generate-ClientCertificateHandlingScripts.ps1" -OutputFileName "%CLIENT_CONFIG_DIR_JAVA%\Uninstall-Db2-SSL-Support-Java.bat" -ServerHostname "%SERVER_HOSTNAME%" -CertFile "%CERT_FILE%" -Action "remove" -Target "java"

REM Generate DBeaver certificate management scripts
echo Creating DBeaver certificate import script...
pwsh.exe -ExecutionPolicy Bypass -File "%OptPath%\DedgePshApps\Db2-AddServerSslSupport\Generate-ClientCertificateHandlingScripts.ps1" -OutputFileName "%CLIENT_CONFIG_DIR_DBEAVER%\Install-Db2-SSL-Support-Dbeaver.bat" -ServerHostname "%SERVER_HOSTNAME%" -CertFile "%CERT_FILE%" -Action "add" -Target "dbeaver" -Krb5IniPath "%KERBEROS_DIR%\krb5.ini" -SslPort "%SSL_PORT%" -DatabaseName "%DATABASE_NAME%" -DatabasePort "%DATABASE_PORT%"

echo Creating DBeaver certificate removal script...
pwsh.exe -ExecutionPolicy Bypass -File "%OptPath%\DedgePshApps\Db2-AddServerSslSupport\Generate-ClientCertificateHandlingScripts.ps1" -OutputFileName "%CLIENT_CONFIG_DIR_DBEAVER%\Uninstall-Db2-SSL-Support-Dbeaver.bat" -ServerHostname "%SERVER_HOSTNAME%" -CertFile "%CERT_FILE%" -Action "remove" -Target "dbeaver"

REM Generate OLE DB certificate management scripts
echo Creating OLE DB certificate import script...
pwsh.exe -ExecutionPolicy Bypass -File "%OptPath%\DedgePshApps\Db2-AddServerSslSupport\Generate-ClientCertificateHandlingScripts.ps1" -OutputFileName "%CLIENT_CONFIG_DIR_OLEDB%\Install-Db2-SSL-Support-OleDb.bat" -ServerHostname "%SERVER_HOSTNAME%" -CertFile "%CERT_FILE%" -Action "add" -Target "oledb" -Krb5IniPath "%KERBEROS_DIR%\krb5.ini" -SslPort "%SSL_PORT%" -DatabaseName "%DATABASE_NAME%" -DatabasePort "%DATABASE_PORT%"

echo Creating OLE DB certificate removal script...
pwsh.exe -ExecutionPolicy Bypass -File "%OptPath%\DedgePshApps\Db2-AddServerSslSupport\Generate-ClientCertificateHandlingScripts.ps1" -OutputFileName "%CLIENT_CONFIG_DIR_OLEDB%\Uninstall-Db2-SSL-Support-OleDb.bat" -ServerHostname "%SERVER_HOSTNAME%" -CertFile "%CERT_FILE%" -Action "remove" -Target "oledb"

echo - Enhanced certificate management scripts created for all client types

echo.
