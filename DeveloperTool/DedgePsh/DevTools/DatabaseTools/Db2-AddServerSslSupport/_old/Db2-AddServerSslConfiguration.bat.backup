echo - Java/JDBC: %CLIENT_CONFIG_DIR_JAVA%\Uninstall-Db2-SSL-Support-Java.bat
echo - DBeaver: %CLIENT_CONFIG_DIR_DBEAVER%\Install-Db2-SSL-Support-Dbeaver.bat
echo - DBeaver: %CLIENT_CONFIG_DIR_DBEAVER%\Uninstall-Db2-SSL-Support-Dbeaver.bat
