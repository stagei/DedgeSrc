echo echo Current user: %%USERNAME%%@%%USERDOMAIN%%                                                                                                                                            >> "%CLIENT_CONFIG_DIR%\Test-Ssl-Connection-From-Client.bat"
echo.                                                                                                                                                                                          >> "%CLIENT_CONFIG_DIR%\Test-Ssl-Connection-From-Client.bat"
echo REM Test SSL port connectivity                                                                                                                                                            >> "%CLIENT_CONFIG_DIR%\Test-Ssl-Connection-From-Client.bat"
echo powershell -Command "Test-NetConnection -ComputerName %SERVER_HOSTNAME% -Port %SSL_PORT%"                                                                                                 >> "%CLIENT_CONFIG_DIR%\Test-Ssl-Connection-From-Client.bat"
echo.                                                                                                                                                                                          >> "%CLIENT_CONFIG_DIR%\Test-Ssl-Connection-From-Client.bat"
