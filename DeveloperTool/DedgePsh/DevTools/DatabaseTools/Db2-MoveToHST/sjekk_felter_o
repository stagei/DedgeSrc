--Sjekk fřr export/import at det ikke har kommet til nye kolonner i BASISPRO
--
--  Alle tabeller, bortsett fra VAREBEVEGELSE skal ha ett felt mer i BASISHST (AAR)
--
--        
select 'BASISPRO', substr(TABNAME,1,32), count(*) 
 from syscat.columns
--select substr(TABNAME,1,32), substr(COLNAME,1,32) from syscat.columns
where TABSCHEMA = 'DBM'
and TABNAME IN (
'H_ORDREHODE',
'H_ORDRELINJER',
'H_ORDREMERKNAD',
'LASS',
'VAREBEVEGELSE',
'KORRIGERINGER')
group by tabname
order by tabname;
connect to basishst;
select 'BASISHST', substr(TABNAME,1,32), count(*) 
 from syscat.columns
--select substr(TABNAME,1,32), substr(COLNAME,1,32) from syscat.columns
where TABSCHEMA = 'DBM'
and TABNAME IN (
'H_ORDREHODE',
'H_ORDRELINJER',
'H_ORDREMERKNAD',
'LASS',
'VAREBEVEGELSE',
'KORRIGERINGER')
group by tabname
order by tabname;
