 EXPORT TO K:\FKAVD\BASISHST\EBH.IXF OF IXF
 SELECT DEC(SUBSTR(CHAR(A.REGDATO),1,4)), A.*
 FROM DBM.EGETBRUK_HODE A
 WHERE A.REGDATO < 20010101 ;
