 EXPORT TO K:\FKAVD\BASISHST\EBL.IXF OF IXF
 SELECT DEC(SUBSTR(CHAR(A.REGDATO),1,4)), B.*
 FROM DBM.EGETBRUK_HODE A  ,
      DBM.EGETBRUK_LINJE B
 WHERE B.ORDRENR = A.ORDRENR
 AND   B.AVDNR   = A.AVDNR
 AND   A.REGDATO < 20010101 ;
