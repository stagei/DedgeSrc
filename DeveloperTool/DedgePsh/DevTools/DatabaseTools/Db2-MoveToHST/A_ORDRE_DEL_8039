--CONNECT TO BASISPRO; Endret til BASISREG kjřring 02.12.2018
CONNECT TO BASISREG;
      delete
  from dbm.ah_ordrehode h
  where date(h.tidspunkt) < (current date - 4 years)
  and h.avdnr = 8039
  and month(h.tidspunkt) between 01 and 03
  and  exists (select 1 from dbm.ah_ordre_til_hist_8039 a
               where  h.avdnr = a.avdnr
               and    h.ordrenr = a.ordrenr
               and a.status = ' ');
