INSERT INTO DBM.BEST_TIL_HIST
(SELECT DEC(SUBSTR(CHAR(ORDREDATO),1,4)), ORDRENR, AVDNR, CURRENT TIMESTAMP, ' '
   FROM DBM.BESTHODE
where ordrenr between  666900 and 667100
   );
