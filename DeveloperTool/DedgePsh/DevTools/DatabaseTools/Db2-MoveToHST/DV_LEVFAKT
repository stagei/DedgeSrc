CREATE OR REPLACE VIEW DV.LEVFAKT  (
  FOMR,
  FKNR,
  ORDRENR,
  AAR,                    -- ¤ NYTT
  LEVNR,
  AVDNR,
  VALKODE,
  FAKT_DATO,
  FORF_DATO,
  RAB_DATO,
  POST_DATO,
  VAL_BELOP,
  NTO_BELOP,
  RAB_BELOP,
  MVA_BELOP,
  BILAGSNR,
  BETBET,
  VALFAKTOR,
  FAKO_UT,
  FAKO_STATUS,
  OKO_STATUS,
  FAKT_TYPE,
  KORR_AARSAK,
  ANKO_TIDSPUNKT,
  GODKJ_TIDSPUNKT,
  MAN_RESK_LEVNR,
  LEVFAKTNR,
  LNR,
  LNR_REF,
  LINJETYPE,
  LEVVARENR,
  VARENAVN,
  ANTALL,
  PRIS,
  LEVNR_ORDRE,
  LEVNR_VARE,
  LEVNR_VARGR,
  HOVEDVAREGR,
  LNR_REF_INIT,
  MVA_SATS_KODE,
  MVA_SATS
  ) as
SELECT 
--DECIMAL(800,3,0),
  FK.FOMRVARE(
     CASE WHEN L.LNR_REF = 0 THEN   DECIMAL(0,8,0) 
       ELSE ( 
     SELECT IAL.FKNR
      FROM DBM.A_BESTHODE IAH, DBM.A_BESTLIN IAL
      WHERE IAH.AVDNR       = IAL.AVDNR
         AND  IAH.ORDRENR   = IAL.ORDRENR
         AND  IAH.AVDNR          = H.AVDNR
         AND   IAH.ORDRENR    = H.ORDRENR
         AND  IAH.LEVNR     = H.LEVNR
         AND  L.LNR_REF   = IAL.LINJE
      UNION
      SELECT IL.FKNR
      FROM DBM.BESTHODE IH, DBM.BESTLIN IL
       WHERE IH.AVDNR = IL.AVDNR
         AND  IH.ORDRENR = IL.ORDRENR
         AND  IH.AVDNR          = H.AVDNR
         AND    IH.ORDRENR    = H.ORDRENR
         AND  IH.LEVNR   = H.LEVNR
         AND  L.LNR_REF   = IL.LINJE
      UNION
       SELECT  HIAL.FKNR
      FROM HST.AH_BESTHODE HIAH, HST.AH_BESTLIN HIAL
      WHERE HIAH.AAR = HIAL.AAR
        AND   HIAH.AVDNR       = HIAL.AVDNR
         AND  HIAH.ORDRENR   = HIAL.ORDRENR
         AND  HIAH.AVDNR          = H.AVDNR
         AND   HIAH.ORDRENR    = H.ORDRENR
         AND  HIAH.LEVNR     = H.LEVNR
         AND  L.LNR_REF    = HIAL.LINJE
--       AND HIAH.AAR BETWEEN YEAR(H.ANKO_TIDSPUNKT) - 1 AND YEAR(H.ANKO_TIDSPUNKT)
           AND HIAH.AAR > 2007
         AND NOT EXISTS (SELECT 1 FROM DBM.BEST_EKST_DUB D
                 WHERE D.AVDNR = H.AVDNR
                 AND D.ORDRENR = H.ORDRENR
                 AND D.LEVNR = H.LEVNR)
      UNION
      SELECT HIL.FKNR
      FROM HST.H_BESTHODE HIH, HST.H_BESTLIN HIL
      WHERE HIH.AAR = HIL.AAR
        AND   HIH.AVDNR = HIL.AVDNR
         AND  HIH.ORDRENR = HIL.ORDRENR
        AND   HIH.AVDNR          = H.AVDNR
         AND  HIH.ORDRENR    = H.ORDRENR
         AND  HIH.LEVNR     = H.LEVNR
         AND  L.LNR_REF    = HIL.LINJE
         AND HIH.AAR > 2007
--       AND HIH.AAR BETWEEN YEAR(H.ANKO_TIDSPUNKT) - 1 AND YEAR(H.ANKO_TIDSPUNKT)
         AND NOT EXISTS (SELECT 1 FROM DBM.BEST_EKST_DUB D
                 WHERE D.AVDNR = H.AVDNR
                 AND D.ORDRENR = H.ORDRENR
                 AND D.LEVNR = H.LEVNR)
         )   END ,
      H.AVDNR) as FOMR,
     CASE WHEN L.LNR_REF = 0 THEN   DECIMAL(0,8,0) 
       ELSE ( 
  SELECT IAL.FKNR
   FROM DBM.A_BESTHODE IAH, DBM.A_BESTLIN IAL
   WHERE IAH.AVDNR       = IAL.AVDNR
      AND  IAH.ORDRENR   = IAL.ORDRENR
      AND  IAH.AVDNR          = H.AVDNR
      AND   IAH.ORDRENR    = H.ORDRENR
      AND  IAH.LEVNR     = H.LEVNR
      AND  L.LNR_REF   = IAL.LINJE
   UNION
   SELECT IL.FKNR
   FROM DBM.BESTHODE IH, DBM.BESTLIN IL
    WHERE IH.AVDNR = IL.AVDNR
      AND  IH.ORDRENR = IL.ORDRENR
      AND  IH.AVDNR          = H.AVDNR
      AND    IH.ORDRENR    = H.ORDRENR
      AND  IH.LEVNR   = H.LEVNR
      AND  L.LNR_REF   = IL.LINJE
   UNION
    SELECT  HIAL.FKNR
   FROM HST.AH_BESTHODE HIAH, HST.AH_BESTLIN HIAL
   WHERE HIAH.AAR = HIAL.AAR 
     AND   HIAH.AVDNR       = HIAL.AVDNR
      AND  HIAH.ORDRENR   = HIAL.ORDRENR
      AND  HIAH.AVDNR          = H.AVDNR
      AND   HIAH.ORDRENR    = H.ORDRENR
      AND  HIAH.LEVNR     = H.LEVNR
      AND  L.LNR_REF    = HIAL.LINJE
      AND HIAH.AAR > 2007
--    AND HIAH.AAR BETWEEN YEAR(H.ANKO_TIDSPUNKT) - 1 AND YEAR(H.ANKO_TIDSPUNKT)
      AND NOT EXISTS (SELECT 1 FROM DBM.BEST_EKST_DUB D
              WHERE D.AVDNR = H.AVDNR
              AND D.ORDRENR = H.ORDRENR
              AND D.LEVNR = H.LEVNR)
   UNION
   SELECT HIL.FKNR
   FROM HST.H_BESTHODE HIH, HST.H_BESTLIN HIL
   WHERE HIH.AAR = HIL.AAR     
     AND   HIH.AVDNR = HIL.AVDNR
      AND  HIH.ORDRENR = HIL.ORDRENR
     AND   HIH.AVDNR          = H.AVDNR
      AND  HIH.ORDRENR    = H.ORDRENR
      AND  HIH.LEVNR     = H.LEVNR
      AND  L.LNR_REF    = HIL.LINJE
      AND HIH.AAR > 2007
--    AND HIH.AAR BETWEEN YEAR(H.ANKO_TIDSPUNKT) - 1 AND YEAR(H.ANKO_TIDSPUNKT)
      AND NOT EXISTS (SELECT 1 FROM DBM.BEST_EKST_DUB D
              WHERE D.AVDNR = H.AVDNR
              AND D.ORDRENR = H.ORDRENR
              AND D.LEVNR = H.LEVNR) 
      )   END ,
       H.ORDRENR,
  (SELECT DEC(SUBSTR(CHAR(IAH.ORDREDATO),1,4),4,0)
   FROM DBM.A_BESTHODE IAH
   WHERE   IAH.AVDNR     = H.AVDNR
      AND  IAH.ORDRENR   = H.ORDRENR
      AND  IAH.LEVNR     = H.LEVNR
   UNION
   SELECT DEC(SUBSTR(CHAR(IH.ORDREDATO),1,4),4,0)
   FROM DBM.BESTHODE IH
      WHERE  IH.AVDNR   = H.AVDNR
      AND    IH.ORDRENR = H.ORDRENR
      AND    IH.LEVNR   = H.LEVNR
   UNION
    SELECT  HIAH.AAR
   FROM HST.AH_BESTHODE HIAH
   WHERE   HIAH.AVDNR      = H.AVDNR
      AND  HIAH.ORDRENR    = H.ORDRENR
      AND  HIAH.LEVNR      = H.LEVNR
      AND HIAH.AAR > 2007
      AND NOT EXISTS (SELECT 1 FROM DBM.BEST_EKST_DUB D
              WHERE D.AVDNR = H.AVDNR
              AND D.ORDRENR = H.ORDRENR
              AND D.LEVNR = H.LEVNR)
   UNION
   SELECT HIH.AAR
   FROM HST.H_BESTHODE HIH
   WHERE   HIH.AVDNR          = H.AVDNR
      AND  HIH.ORDRENR    = H.ORDRENR
      AND  HIH.LEVNR     = H.LEVNR
      AND HIH.AAR > 2007
      AND NOT EXISTS (SELECT 1 FROM DBM.BEST_EKST_DUB D
              WHERE D.AVDNR = H.AVDNR
              AND D.ORDRENR = H.ORDRENR
              AND D.LEVNR = H.LEVNR) 
       ) AS AAR,
       H.LEVNR,
       H.AVDNR,
       H.VALKODE,
       H.FAKT_DATO,
       H.FORF_DATO,
       H.RAB_DATO,
       H.POST_DATO,
      DECIMAL(((H.VAL_BELOP/
           (SELECT SUM(LS.BELOP)
            FROM DBM.H_LEV_FAKT_LINJER LS
            WHERE LS.LEVFAKTNR = L.LEVFAKTNR
            AND LS.REG_TIDSPUNKT = L.REG_TIDSPUNKT
            AND LS.LINJETYPE <> '3'))
       * L.BELOP),14,2) AS VAL_BELOP,
       DECIMAL(((H.NTO_BELOP/
      (SELECT SUM(LS.BELOP)
            FROM DBM.H_LEV_FAKT_LINJER LS
            WHERE LS.LEVFAKTNR = L.LEVFAKTNR
            AND LS.REG_TIDSPUNKT = L.REG_TIDSPUNKT
            AND LS.LINJETYPE <> '3'))
      * L.BELOP),14,2) AS NTO_BELOP,
       DECIMAL(((L.ANTALL * L.PRIS) - L.BELOP),14,2)  AS RAB_BELOP,
       DECIMAL(((H.MVA_BELOP/
      (SELECT SUM(LS.BELOP)
            FROM DBM.H_LEV_FAKT_LINJER LS
            WHERE LS.LEVFAKTNR = L.LEVFAKTNR
            AND LS.REG_TIDSPUNKT = L.REG_TIDSPUNKT
            AND LS.LINJETYPE <> '3'))
      * L.BELOP),14,2) AS MVA_BELOP,
       H.BILAGSNR,
       H.BETBET,
       H.VALFAKTOR,
       H.FAKO_UT,
       H.FAKO_STATUS,
       H.OKO_STATUS,
       H.FAKT_TYPE,
       H.KORR_AARSAK,
       H.ANKO_TIDSPUNKT,
       H.GODKJ_TIDSPUNKT,
       H.MAN_RESK_LEVNR,
       L.LEVFAKTNR,
       L.LNR,
       L.LNR_REF,
       L.LINJETYPE,
       L.LEVVARENR,
       L.VARENAVN,
       L.ANTALL,
       L.PRIS,
       L.LEVNR_ORDRE,
       L.LEVNR_VARE,
       L.LEVNR_VARGR,
       L.HOVEDVAREGR,
       L.LNR_REF_INIT,
       L.MVA_SATS_KODE,
       L.MVA_SATS
FROM DBM.H_LEV_FAKTURA H, DBM.H_LEV_FAKT_LINJER L              
 WHERE H.LEVFAKTNR = L.LEVFAKTNR
 AND H.REG_TIDSPUNKT = L.REG_TIDSPUNKT
 AND H.POST_DATO > 20081231
 AND L.LINJETYPE <> '3'
 AND L.BELOP <> 0
 and not (date(h.reg_tidspunkt) = '2013-02-27' and h.levfaktnr = '105185')
 and not (date(h.reg_tidspunkt) = '2013-03-12' and h.levfaktnr = '8091770')
 and not (date(h.reg_tidspunkt) = '2014-02-11' and h.levfaktnr = '112381')
 and not (date(h.reg_tidspunkt) = '2017-06-16' and h.levfaktnr = '133676')
 and not (date(h.reg_tidspunkt) = '2017-07-14' and h.levfaktnr = '12481')
 and not (date(h.reg_tidspunkt) = '2017-08-08' and h.levfaktnr = '134033')
 and not (date(h.reg_tidspunkt) = '2018-09-05' and h.levfaktnr = '104628')
-- and h.levfaktnr <> '21215168'
 ;
grant select on table dv.levfakt to public;

