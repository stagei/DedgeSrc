WHERE (AVDNR BETWEEN 7000 AND 7999)
AND (EXISTS (SELECT 1 FROM DBM.BEST_TIL_HIST h WHERE A.AVDNR = H.AVDNR AND a.ordrenr < 1000000 and H.ORDRENR = A.ORDRENR))
and (not(avdnr = 7310 and ordrenr = 925665));
