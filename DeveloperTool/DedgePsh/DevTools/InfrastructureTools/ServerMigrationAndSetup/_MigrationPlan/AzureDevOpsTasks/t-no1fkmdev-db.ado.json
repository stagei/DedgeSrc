    {
      "taskname": "t-no1fkmdev-db-RunGenerateScriptsStep1",
      "server": "t-no1fkmdev-db",
      "fields": [
        {
          "path": "/fields/System.Title",
          "value": "t-no1fkmdev-db-RunGenerateScriptsStep1",
          "op": "add"
        },
        {
          "path": "/fields/System.Description",
          "value": "Start Db2 Clp i admin konsoll og kjør kommando: cd F:\\Db2Restore\\GenScripts.\nKjør følgende skript i rekkefølge:\n01_db2_create_database.*.sql\n01_db2_create_log_and_tablespace_folders*.bat\n02_db2_config_logs.*.sql\n03_db2_config_etc_services.*.bat\n04_db2_config_svcename.*.sql\n05_db2_generate_restore_container.*.bat\nFiler med suffix .sql kjøres med kommando: db2 -tvf <filnavn>\nFiler med suffix .bat kjøres direkte i db2 konsoll med filnavn kommando: <filnavn>.bat\n\nComment: Dette lager ett utgangspunkt for med korrekt konfigurasjon for å opprette en ny produksjonsdatabase ved migreringstidspunktet\n\nPrerequisites Note: Template engine må kjøres først for å generere skriptene",
          "op": "add"
        },
        {
          "path": "/fields/System.Tags",
          "value": "Server=t-no1fkmdev-db;ServerPart=t-no1fkmdev;Template=test-db-init;default=False",
          "op": "add"
        },
        {
          "path": "/fields/Microsoft.VSTS.Common.AcceptanceCriteria",
          "value": "Prerequisites: t-no1fkmdev-db-RunDb2-TemplateEngine",
          "op": "add"
        }
      ],
      "id": "t-no1fkmdev-db-RunGenerateScriptsStep1"
    },
