          "op": "add"
        },
        {
          "path": "/fields/System.Description",
          "value": "Kjør scriptet 05_db2_restore_container.*.bat. Denne genererer ett skript som kan kjøres for å restore databasen fra en backup-fil\n\nPrerequisites Note: Skriptet delere 01 til 05 må kjøres først",
          "op": "add"
        },
        {
          "path": "/fields/System.Tags",
          "value": "Server=t-no1fkmdev-db;ServerPart=t-no1fkmdev;Template=test-db-init;default=False",
          "op": "add"
        },
        {
          "path": "/fields/Microsoft.VSTS.Common.AcceptanceCriteria",
