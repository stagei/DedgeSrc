    {
      "taskname": "p-no1fkmprd-app-VerifyDb2Client",
      "server": "p-no1fkmprd-app",
      "fields": [
        {
          "path": "/fields/System.Title",
          "value": "p-no1fkmprd-app-VerifyDb2Client",
          "op": "add"
        },
        {
          "path": "/fields/System.Description",
          "value": "Verifiser at IBM Db2 klient er installert. Hvis ikke installert, kjør pwsh.exe og bruk kommandoen 'Get-App' for å installere.\n\nComment: IBM Db2 klient må være installert for å kunne koble til databasen",
          "op": "add"
        },
        {
          "path": "/fields/System.Tags",
          "value": "Server=p-no1fkmprd-app;ServerPart=p-no1fkmprd;Template=init-app-servers;default=False",
          "op": "add"
        }
      ],
      "id": "p-no1fkmprd-app-VerifyDb2Client"
    },
    {
      "taskname": "p-no1fkmprd-app-ConfigureDb2Client",
      "server": "p-no1fkmprd-app",
      "fields": [
        {
          "path": "/fields/System.Title",
          "value": "p-no1fkmprd-app-ConfigureDb2Client",
          "op": "add"
        },
        {
          "path": "/fields/System.Description",
          "value": "Kjør pwsh.exe og skriptet Db2ClientConfig\\Db2Kerberos-ClientConfig.ps1 for å sette opp Db2 klienten\n\nComment: Konfigurerer Db2 klienten for Kerberos-autentisering\n\nPrerequisites Note: Db2 klient må være installert og Kerberos må være konfigurert på databaseserveren p-no1fkmprd-db",
          "op": "add"
        },
        {
          "path": "/fields/System.Tags",
          "value": "Server=p-no1fkmprd-app;ServerPart=p-no1fkmprd;Template=init-app-servers;default=False",
          "op": "add"
        },
        {
          "path": "/fields/Microsoft.VSTS.Common.AcceptanceCriteria",
          "value": "Prerequisites: p-no1fkmprd-app-VerifyDb2Client; p-no1fkmprd-db-VerifyKerberosConfig",
          "op": "add"
        }
      ],
      "id": "p-no1fkmprd-app-ConfigureDb2Client"
    },
    {
      "taskname": "p-no1fkmprd-db-CatalogDb2Kerberos",
      "server": "p-no1fkmprd-app",
      "fields": [
        {
          "path": "/fields/System.Title",
          "value": "p-no1fkmprd-db-CatalogDb2Kerberos",
          "op": "add"
        },
        {
          "path": "/fields/System.Description",
          "value": "I Db2 Clp admin konsoll kjør kommandoen: xcopy \\dedge-server\\DedgeCommon\\Software\\Config\\Db2Catalog\\Kerberos\\cat_db2_FKMPRD_kerberos.bat c:\\TEMPFK /Y \n. Dette vil katalogisere databasen for Kerberos-autentisering.\n\nComment: Katalogiserer databasen for Kerberos-autentisering\n\nPrerequisites Note: DB2-nøkkel må være bestilt først",
          "op": "add"
        },
        {
          "path": "/fields/System.Tags",
          "value": "Server=p-no1fkmprd-app;ServerPart=p-no1fkmprd;Database=FKMPRD;Template=init-app-servers;default=False",
          "op": "add"
        },
        {
          "path": "/fields/Microsoft.VSTS.Common.AcceptanceCriteria",
          "value": "Prerequisites: p-no1fkmprd-db-OrderDb2Key",
          "op": "add"
        }
      ],
      "id": "p-no1fkmprd-db-CatalogDb2Kerberos_FKMPRD"
    },
    {
      "taskname": "p-no1fkmprd-app-VerifyKerberosConfig",
      "server": "p-no1fkmprd-app",
      "fields": [
        {
          "path": "/fields/System.Title",
          "value": "p-no1fkmprd-app-VerifyKerberosConfig",
          "op": "add"
        },
        {
          "path": "/fields/System.Description",
          "value": "Verifiser Kerberos-konfigurasjonen ved hjelp av Db2 clp i admin konsoll og kjør kommandoen: CREATE TABLE TEST (ID INT);INSERT INTO TEST VALUES (1);SELECT * FROM TEST;DROP TABLE TEST;\nHvis dette lykkes fungerer databasetilkoblingen.\n\nComment: Verifiser tilkobling fra appserver til database\n\nPrerequisites Note: Db2 klient må være konfigurert",
          "op": "add"
        },
        {
          "path": "/fields/System.Tags",
          "value": "Server=p-no1fkmprd-app;ServerPart=p-no1fkmprd;Template=init-app-servers;default=False",
          "op": "add"
        },
        {
          "path": "/fields/Microsoft.VSTS.Common.AcceptanceCriteria",
          "value": "Prerequisites: p-no1fkmprd-app-ConfigureDb2Client",
          "op": "add"
        }
      ],
      "id": "p-no1fkmprd-app-VerifyKerberosConfig"
    },
