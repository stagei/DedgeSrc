          "op": "add"
        },
        {
          "path": "/fields/System.Description",
          "value": "På din lokale pc, start Db2 Clp admin konsoll og kjør kommandoen: xcopy \\dedge-server\\DedgeCommon\\Software\\Config\\Db2Catalog\\Kerberos\\cat_db2_FKMPRD_kerberos.bat c:\\TEMPFK /Y \n. Dette vil katalogisere databasen for Kerberos-autentisering.\n\nComment: Katalogiserer databasen for Kerberos-autentisering\n\nPrerequisites Note: DB2-nøkkel må være bestilt først",
          "op": "add"
        },
        {
          "path": "/fields/System.Tags",
          "value": "Server=p-no1fkmprd-app;ServerPart=p-no1fkmprd;Database=FKMPRD;Template=init-app-servers;default=False",
