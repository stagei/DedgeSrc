          "op": "add"
        },
        {
          "path": "/fields/System.Description",
          "value": "Verifiser Kerberos-konfigurasjonen ved hjelp av Dbeaver og lag connection til databasen med DB2NT bruker.\nLim inn dette i Dbeaver og kjør kommandoen med Alt+X: CREATE TABLE TEST (ID INT);INSERT INTO TEST VALUES (1);SELECT * FROM TEST;DROP TABLE TEST;ROLLBACK;\nHvis dette lykkes fungerer databasen fra Dbeaver. \n\nPrerequisites Note: Kerberos-oppsett må være fullført",
          "op": "add"
        },
        {
          "path": "/fields/System.Tags",
